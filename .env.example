# --- SMTP (eNom example) — copy to .env.local for development; never commit secrets ---
SMTP_HOST=mail.enom.com
SMTP_PORT=465
# true for port 465 (SSL); false for 587 + STARTTLS
SMTP_SECURE=true
SMTP_USER=request@croninortho.com
SMTP_PASS=

# Where form submissions are delivered (often same as SMTP_USER)
RECIPIENT_EMAIL=request@croninortho.com

# Optional: comma-separated origins allowed to call this API (CORS), for cross-origin static sites
# ALLOWED_ORIGINS=https://croninortho.com,https://www.croninortho.com,http://localhost:3000

# If the website is static (GitHub Pages), set this at build time to your live API URL
# (include trailing slash if your host uses trailingSlash, e.g. Next defaults):
# NEXT_PUBLIC_CONTACT_API_URL=https://your-deployment.vercel.app/api/contact/
